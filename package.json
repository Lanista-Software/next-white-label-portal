{
  "name": "next-white-label-portal",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node ../../scripts/clean-next-dev-cache.mjs && next dev",
    "build": "next build",
    "start": "next start",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "contentrain:generate": "contentrain generate",
    "deploy:netlify": "next build"
  },
  "dependencies": {
    "@contentrain/query": "^5.1.0",
    "next": "^15.5.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "contentrain": "^0.3.1",
    "typescript": "^5.9.2"
  },
  "imports": {
    "#contentrain": {
      "types": "./.contentrain/client/index.d.ts",
      "import": "./.contentrain/client/index.mjs",
      "require": "./.contentrain/client/index.cjs"
    },
    "#contentrain/*": {
      "types": "./.contentrain/client/*.d.ts",
      "import": "./.contentrain/client/*.mjs",
      "require": "./.contentrain/client/*.cjs"
    }
  }
}
